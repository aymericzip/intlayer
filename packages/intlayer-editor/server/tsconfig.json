{
  "extends": "@utils/ts-config",
  "include": ["src/**/*"],
  "compilerOptions": {
    "outDir": "dist",
    "paths": {
      "@controllers/*": ["./src/controllers/*"],
      "@services/*": ["./src/services/*"],
      "@routes/*": ["./src/routes/*"],
      "@middlewares/*": ["./src/middlewares/*"],
      "@schemas/*": ["./src/schemas/*"],
      "@utils/*": ["./src/utils/*"],
      "@/*": ["./src/*"]
    }
  }
}
