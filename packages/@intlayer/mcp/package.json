{
  "name": "@intlayer/mcp",
  "version": "8.12.3",
  "private": false,
  "description": "Intlayer MCP server. Handle MCP to help IDE to use Intlayer. It build, fill, pull, push, dictionaries",
  "keywords": [
    "intlayer",
    "mcp",
    "mcp-server",
    "mcp-proxy",
    "documentation",
    "cli",
    "mcp-lsp",
    "mcp-language-server"
  ],
  "homepage": "https://intlayer.org",
  "bugs": {
    "url": "https://github.com/aymericzip/intlayer/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aymericzip/intlayer.git"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "Aymeric PINEAU",
    "url": "https://github.com/aymericzip"
  },
  "contributors": [
    {
      "name": "Aymeric Pineau",
      "email": "ay.pineau@gmail.com",
      "url": "https://github.com/aymericzip"
    }
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/types/server/stdio.d.ts",
      "require": "./dist/esm/server/stdio.mjs",
      "import": "./dist/esm/server/stdio.mjs"
    },
    "./sse": {
      "types": "./dist/types/server/sse.d.ts",
      "require": "./dist/esm/server/sse.mjs",
      "import": "./dist/esm/server/sse.mjs"
    },
    "./client": {
      "types": "./dist/types/client/client.d.ts",
      "require": "./dist/esm/client/client.mjs",
      "import": "./dist/esm/client/client.mjs"
    },
    "./tools": {
      "types": "./dist/types/tools/index.d.ts",
      "require": "./dist/esm/tools/index.mjs",
      "import": "./dist/esm/tools/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "main": "dist/esm/server/stdio.mjs",
  "module": "dist/esm/server/stdio.mjs",
  "types": "dist/types/server/stdio.d.ts",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types/server/stdio.d.ts"
      ],
      "sse": [
        "./dist/types/server/sse.d.ts"
      ],
      "client": [
        "./dist/types/client/client.d.ts"
      ],
      "tools": [
        "./dist/types/tools/index.d.ts"
      ],
      "package.json": [
        "./package.json"
      ]
    }
  },
  "bin": "dist/esm/server/stdio.mjs",
  "files": [
    "./dist",
    "./package.json"
  ],
  "scripts": {
    "build": "bun --bun tsdown --config tsdown.config.ts",
    "build:ci": "bun --bun tsdown --config tsdown.config.ts",
    "clean": "bun --bun rimraf ./dist .turbo",
    "dev": "bun --bun tsdown --config tsdown.config.ts --watch",
    "format": "bun --bun biome format . --check",
    "format:fix": "bun --bun biome format --write .",
    "lint": "bun --bun biome lint .",
    "lint:fix": "bun --bun biome lint --write .",
    "manange:permissions": "bun -e \"require('fs').chmodSync('dist/esm/server/stdio.mjs', 0o755); require('fs').chmodSync('dist/esm/server/sse.mjs', 0o755)\"",
    "process-files": "ts-node src/transpiler/processFilesCLI.ts --dir $npm_config_dir --extension $npm_config_extension --no-node-snapshot",
    "prepublish": "cp -f ../../../README.md ./README.md",
    "publish": "bun publish || true",
    "publish:canary": "bun publish --access public --tag canary || true",
    "publish:latest": "bun publish --access public --tag latest || true",
    "start": "bun start:stdio",
    "start:client": "bun dist/esm/client/sse.mjs",
    "start:docker": "docker run --rm -p 3000:3000 --name intlayer-mcp-app intlayer-mcp",
    "start:inspector": "npx @modelcontextprotocol/inspector bun dist/esm/server/stdio.mjs",
    "start:inspector:sse": "npx @modelcontextprotocol/inspector bun dist/esm/server/sse.mjs",
    "start:sse": "bun dist/esm/server/sse.mjs",
    "start:stdio": "bun dist/esm/server/stdio.mjs",
    "test": "bun --bun vitest run",
    "test:watch": "bun --bun vitest",
    "typecheck": "tsc --noEmit --project tsconfig.types.json"
  },
  "dependencies": {
    "@ai-sdk/mcp": "1.0.46",
    "@fastify/cors": "11.2.0",
    "@fastify/helmet": "13.0.2",
    "@intlayer/api": "workspace:*",
    "@intlayer/chokidar": "workspace:*",
    "@intlayer/cli": "workspace:*",
    "@intlayer/config": "workspace:*",
    "@intlayer/docs": "workspace:*",
    "@intlayer/types": "workspace:*",
    "dotenv": "17.4.2",
    "fastify": "5.8.5",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@intlayer/types": "workspace:*",
    "@types/node": "25.9.2",
    "@utils/ts-config": "workspace:*",
    "@utils/ts-config-types": "workspace:*",
    "@utils/tsdown-config": "workspace:*",
    "rimraf": "6.1.3",
    "tsdown": "0.21.10",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "engines": {
    "node": ">=14.18"
  },
  "bug": {
    "url": "https://github.com/aymericzip/intlayer/issues"
  }
}
