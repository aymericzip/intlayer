{
  "name": "website-tanstack",
  "version": "9.0.0-canary.12",
  "private": true,
  "description": "Intlayer Website include the landing page and the documentation of the intlayer project.",
  "keywords": [
    "intlayer",
    "website",
    "application",
    "editor",
    "typescript",
    "javascript",
    "json",
    "file"
  ],
  "homepage": "https://intlayer.org",
  "bugs": {
    "url": "https://github.com/aymericzip/intlayer/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aymericzip/intlayer.git"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "Aymeric PINEAU",
    "url": "https://github.com/aymericzip"
  },
  "contributors": [
    {
      "name": "Aymeric Pineau",
      "email": "ay.pineau@gmail.com",
      "url": "https://github.com/aymericzip"
    }
  ],
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "baidu-push": "bun --env-file=.env.production.local ./scripts/baidu-push.ts",
    "build": "bun --bun vite build",
    "postbuild": "bun scripts/generate-sw.ts",
    "dev": "bun --bun vite dev --port 5174",
    "editor": "intlayer-editor start --bun",
    "generate-pwa-assets": "pwa-asset-generator --preset minimal ../../packages/@intlayer/design-system/src/components/Logo/logo_circle_wite.svg ./public/assets/",
    "prettier": "prettier . --check",
    "prettier:fix": "prettier . --write",
    "preserve": "bun --env-file=.env.production ./scripts/purge-cloudflare-cache.ts",
    "serve": "npx intlayer serve --bun",
    "start": "bun run .output/server/index.mjs",
    "start:editor": "bun intlayer-editor start --with 'bun --bun vite dev'",
    "test": "bun --bun vitest run"
  },
  "dependencies": {
    "@intlayer/api": "workspace:*",
    "@intlayer/config": "workspace:*",
    "@intlayer/core": "workspace:*",
    "@intlayer/design-system": "workspace:*",
    "@intlayer/dictionaries-entry": "workspace:*",
    "@intlayer/docs": "workspace:*",
    "@intlayer/editor-react": "workspace:*",
    "@intlayer/types": "workspace:*",
    "@intlayer/unmerged-dictionaries-entry": "workspace:*",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-router": "1.170.16",
    "@tanstack/react-start": "1.168.26",
    "@tanstack/start-static-server-functions": "^1.167.17",
    "babel-plugin-react-compiler": "1.0.0",
    "chart.js": "4.5.1",
    "defu": "6.1.7",
    "framer-motion": "12.42.2",
    "fuse.js": "7.4.2",
    "intlayer": "workspace:*",
    "lucide-react": "1.23.0",
    "next-themes": "0.4.6",
    "nitro": "latest",
    "posthog-js": "1.396.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-intlayer": "workspace:*",
    "react-virtuoso": "4.18.10",
    "rss": "1.2.2",
    "sharp": "0.35.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@rolldown/plugin-babel": "0.2.3",
    "@tailwindcss/postcss": "4.3.2",
    "@tailwindcss/vite": "4.3.2",
    "@tanstack/router-plugin": "1.168.18",
    "@types/node": "25.9.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/rss": "0.0.32",
    "@utils/ts-config": "workspace:*",
    "@utils/ts-config-types": "workspace:*",
    "@utils/tsdown-config": "workspace:*",
    "@vitejs/plugin-react": "6.0.3",
    "glob": "13.0.6",
    "postcss": "8.5.16",
    "pwa-asset-generator": "8.1.5",
    "raw-loader": "4.0.2",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "vite": "8.1.2",
    "vite-intlayer": "workspace:*",
    "vite-plugin-wasm": "3.6.0",
    "workbox-build": "7.4.1"
  },
  "peerDependencies": {
    "@intlayer/backend": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@intlayer/backend": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "cobe": "2.0.1",
    "intlayer-editor": "workspace:*",
    "react-spring": "10.0.4"
  }
}
