{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@utils/ts-config",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext", "webworker"],
    "allowJs": true,
    "skipLibCheck": false,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "rootDirs": [".", "./.react-router/types"],
    "incremental": true,
    "downlevelIteration": true,
    "types": ["node", "vite/client"],
    "paths": {
      "~/*": ["./src/*"]
    }
  },
  "include": [
    "**/*",
    "**/.server/**/*",
    "**/.client/**/*",
    ".react-router/types/**/*",
    ".intlayer/**/*.ts",
    ".intlayer/types/**/*.ts",
    "../../packages/@intlayer/design-system/src/components/LanguageSection"
  ],
  "exclude": ["node_modules", ".react-router", "build", "public/sw.js"]
}
