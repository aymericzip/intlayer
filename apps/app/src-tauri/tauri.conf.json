{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "intlayer",
  "version": "0.1.0",
  "identifier": "org.intlayer.app",
  "build": {
    "frontendDist": "http://localhost:3000",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "bun --bun vite dev --config tory.vite.config.ts --port 3000",
    "beforeBuildCommand": "bun --bun vite build --config tory.vite.config.ts"
  },
  "app": {
    "windows": [
      {
        "title": "intlayer",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
