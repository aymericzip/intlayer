{
  "name": "app",
  "version": "8.10.0-canary.0",
  "private": true,
  "description": "Intlayer app",
  "homepage": "https://intlayer.org",
  "license": "Apache-2.0",
  "author": {
    "name": "Aymeric PINEAU",
    "url": "https://github.com/aymericzip"
  },
  "sideEffects": false,
  "type": "module",
  "imports": {
    "#/*": "./src/*",
    "#components/*": "./src/components/*",
    "#layouts/*": "./src/layouts/*",
    "#utils/*": "./src/utils/*",
    "#hooks/*": "./src/hooks/*",
    "#assets/*": "./src/assets/*",
    "#structuredData/*": "./src/structuredData/*"
  },
  "main": "out/main/index.js",
  "scripts": {
    "build": "bun --bun vite build",
    "check": "bun --bun biome check",
    "dev": "bun --bun vite dev --port 3000",
    "format": "bun --bun biome format",
    "lint": "bun --bun biome lint",
    "preserve": "bun --env-file=.env.production ./scripts/purge-cloudflare-cache.ts",
    "preview": "bun --bun vite preview",
    "publish": "bash scripts/electron-publish.sh",
    "start": "bun run .output/server/index.mjs",
    "tauri:build": "tauri build --bundles app",
    "tauri:dev": "tauri dev",
    "tauri:start": "bun run .output/server/index.mjs",
    "test": "bun --bun vitest run"
  },
  "dependencies": {
    "@better-auth/sso": "1.6.11",
    "@electron-toolkit/utils": "^4.0.0",
    "@intlayer/api": "workspace:*",
    "@intlayer/config": "workspace:*",
    "@intlayer/core": "workspace:*",
    "@intlayer/design-system": "workspace:*",
    "@intlayer/dictionaries-entry": "workspace:*",
    "@intlayer/editor-react": "workspace:*",
    "@intlayer/types": "workspace:*",
    "@intlayer/unmerged-dictionaries-entry": "workspace:*",
    "@monaco-editor/react": "4.7.0",
    "@posthog/react": "1.9.0",
    "@stripe/react-stripe-js": "6.3.0",
    "@stripe/stripe-js": "9.5.0",
    "@tailwindcss/aspect-ratio": "0.4.2",
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/match-sorter-utils": "8.19.4",
    "@tanstack/react-devtools": "0.10.5",
    "@tanstack/react-query": "5.100.11",
    "@tanstack/react-query-devtools": "5.100.10",
    "@tanstack/react-router": "1.170.3",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/react-router-ssr-query": "1.167.0",
    "@tanstack/react-start": "1.168.5",
    "@tanstack/react-table": "8.21.3",
    "@tanstack/react-virtual": "3.13.24",
    "@tanstack/router-plugin": "1.168.5",
    "defu": "6.1.7",
    "framer-motion": "12.39.0",
    "fuse.js": "7.3.0",
    "intlayer": "workspace:*",
    "lucide-react": "1.16.0",
    "next-themes": "^0.4.6",
    "nitro": "latest",
    "posthog-js": "1.374.2",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "7.76.0",
    "react-intlayer": "workspace:*",
    "react-qr-code": "2.0.21",
    "react-spring": "10.0.3",
    "react-virtuoso": "4.18.7",
    "server-only": "0.0.1",
    "stripe": "^22.1.1",
    "tailwindcss": "4.3.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@intlayer/backend": "workspace:*",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tanstack/devtools-vite": "0.7.0",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.9.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "esbuild": "^0.28.0",
    "jsdom": "29.1.1",
    "remark-gfm": "4.0.1",
    "tauri": "^0.15.0",
    "typescript": "6.0.3",
    "vite": "8.0.13",
    "vite-intlayer": "workspace:*",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "4.1.6",
    "workbox-build": "7.4.1"
  }
}
