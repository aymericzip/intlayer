{
  "name": "intlayer-showcase",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "imports": {
    "#/*": "./src/*",
    "#components/*": "./src/components/*",
    "#layouts/*": "./src/layouts/*",
    "#utils/*": "./src/utils/*",
    "#hooks/*": "./src/hooks/*",
    "#assets/*": "./src/assets/*",
    "#structuredData/*": "./src/structuredData/*"
  },
  "scripts": {
    "build": "bun --bun vite build",
    "check": "bun --bun biome check",
    "dev": "bun --bun vite dev --port 3200",
    "format": "bun --bun biome format",
    "lint": "bun --bun biome lint",
    "preserve": "bun --env-file=.env.production ./scripts/purge-cloudflare-cache.ts",
    "preview": "bun --bun vite preview",
    "start": "bun run .output/server/index.mjs",
    "test": "bun --bun vitest run"
  },
  "dependencies": {
    "@intlayer/api": "workspace:*",
    "@intlayer/config": "workspace:*",
    "@intlayer/core": "workspace:*",
    "@intlayer/design-system": "workspace:*",
    "@intlayer/types": "workspace:*",
    "@posthog/react": "1.9.0",
    "@rolldown/plugin-babel": "^0.2.2",
    "@tailwindcss/aspect-ratio": "0.4.2",
    "@tailwindcss/vite": "4.2.4",
    "@tanstack/match-sorter-utils": "8.19.4",
    "@tanstack/react-devtools": "0.10.2",
    "@tanstack/react-query": "5.100.7",
    "@tanstack/react-query-devtools": "5.100.7",
    "@tanstack/react-router": "1.168.26",
    "@tanstack/react-router-devtools": "1.166.13",
    "@tanstack/react-router-ssr-query": "1.166.12",
    "@tanstack/react-start": "1.167.59",
    "@tanstack/react-table": "8.21.3",
    "@tanstack/router-plugin": "1.167.22",
    "framer-motion": "12.38.0",
    "fuse.js": "7.3.0",
    "intlayer": "workspace:*",
    "lucide-react": "1.14.0",
    "nitro": "latest",
    "posthog-js": "1.372.6",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "7.75.0",
    "react-intlayer": "workspace:*",
    "server-only": "0.0.1",
    "tailwindcss": "4.2.4",
    "zod": "4.4.2"
  },
  "devDependencies": {
    "@tanstack/devtools-vite": "0.6.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "29.1.1",
    "remark-gfm": "4.0.1",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vite-intlayer": "workspace:*",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "4.1.5"
  }
}
