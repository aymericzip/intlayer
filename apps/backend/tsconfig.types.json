{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@utils/ts-config-types",
  "include": ["src/**/*", "types/**/*"],
  "exclude": ["**/*.test.*"],
  "compilerOptions": {
    "outDir": "dist/types",
    "paths": {
      "@controllers/*": ["./src/controllers/*"],
      "@services/*": ["./src/services/*"],
      "@routes/*": ["./src/routes/*"],
      "@webhooks/*": ["./src/webhooks/*"],
      "@middlewares/*": ["./src/middlewares/*"],
      "@logger": ["./src/logger/index"],
      "@schemas/*": ["./src/schemas/*"],
      "@emails/*": ["./src/emails/*"],
      "@utils/*": ["./src/utils/*"],
      "@/*": ["./src/*"]
    }
  }
}
