---
import { Website_Doc_Path } from '@intlayer/design-system/routes';
import { getDocMetadataBySlug } from '@intlayer/docs';
import {
  getLocaleFromPath,
  getPrefix,
  type LocalesValues,
  localeMap,
} from 'intlayer';

export const prerender = true;

export const getStaticPaths = () =>
  localeMap(({ locale }) => ({
    params: { locale: getPrefix(locale).localePrefix },
  }));

const locale = getLocaleFromPath(Astro.url.pathname) as LocalesValues;

// Get the first doc and redirect to it
const docs = await getDocMetadataBySlug([], locale);
const firstDoc = docs[0];
const redirectUrl = firstDoc ? firstDoc.url : Website_Doc_Path;
---

<meta http-equiv="refresh" content={`0; url=${redirectUrl}`} />
<script define:vars={{ redirectUrl }}>
  window.location.replace(redirectUrl);
</script>
