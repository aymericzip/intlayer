---
import { getPreviousNextDocMetadata } from '@components/DocPage/docData';
import { Website_Doc_Path } from '@intlayer/design-system/routes';
import {
  type DocKey,
  getDoc,
  getDocMetadata,
  getDocMetadataBySlug,
} from '@intlayer/docs';
import { urlRenamer } from '@utils/markdown';
import {
  getLocaleFromPath,
  getLocalizedUrl,
  getPrefix,
  type LocalesValues,
  localeMap,
} from 'intlayer';
import { DocPageIsland } from '@/components/islands/DocPageIsland';
import BaseLayout from '@/layouts/BaseLayout.astro';

export const prerender = true;

export const getStaticPaths = async () => {
  const docMetadata = await getDocMetadataBySlug([]);
  const paths = [];

  for (const { locale } of localeMap(({ locale }) => ({ locale }))) {
    for (const meta of docMetadata) {
      // meta.slugs starts with "doc" (e.g. ["doc","get-started"]).
      // The Astro page is at [...locale]/doc/[...slugs], so the "doc" segment
      // is already in the path — we only pass the remainder as the slugs param.
      const slugsParam = meta.slugs.slice(1).join('/');
      // Skip paths handled by dedicated static routes to avoid prerender conflicts.
      if (!slugsParam || slugsParam === 'search' || slugsParam === 'chat')
        continue;
      paths.push({
        params: {
          locale: getPrefix(locale).localePrefix,
          slugs: slugsParam,
        },
        props: { locale, slugs: meta.slugs.slice(1) },
      });
    }
  }

  return paths;
};

const { locale: localeProp, slugs: slugsProp } = Astro.props as {
  locale: LocalesValues;
  slugs: string[];
};
const locale =
  localeProp ?? (getLocaleFromPath(Astro.url.pathname) as LocalesValues);
const slugs =
  slugsProp ??
  (Astro.params.slugs ? String(Astro.params.slugs).split('/') : []);

const docsData = await getDocMetadataBySlug(slugs, locale);
const filteredDocsData = docsData.filter(
  (doc) => doc.slugs.length === slugs.length + 1
);

if (!filteredDocsData || filteredDocsData.length === 0) {
  return Astro.redirect(Website_Doc_Path);
}

const docData = filteredDocsData[0];
const { prevDocData, nextDocData } = getPreviousNextDocMetadata(
  docData.docKey as DocKey,
  locale
);
const defaultDocData = await getDocMetadata(docData.docKey as DocKey);
const file = await getDoc(docData?.docKey as DocKey, locale);
const docContent = urlRenamer(file, locale);

const nextDoc = nextDocData?.docs
  ? {
      title: nextDocData.title,
      url: getLocalizedUrl(nextDocData.docs.relativeUrl, locale),
    }
  : undefined;
const prevDoc = prevDocData?.docs
  ? {
      title: prevDocData.title,
      url: getLocalizedUrl(prevDocData.docs.relativeUrl, locale),
    }
  : undefined;

// Serialize docData to plain object to ensure it's JSON-serializable
const serializedDocData = {
  title: docData.title,
  description: docData.description,
  keywords: docData.keywords,
  createdAt: String(docData.createdAt),
  updatedAt: String(docData.updatedAt),
  url: docData.url,
  docKey: String(docData.docKey),
  githubUrl: docData.githubUrl ?? '',
  relativeUrl: docData.relativeUrl ?? '',
  applicationTemplate: docData.applicationTemplate,
  applicationShowcase: docData.applicationShowcase,
  youtubeVideo: docData.youtubeVideo,
  author: docData.author,
  history: (docData.history ?? []).map((h: any) => ({
    date: String(h.date),
    version: String(h.version ?? ''),
    changes: String(h.changes ?? ''),
  })),
  slugs: docData.slugs,
};
const docPageProps = {
  locale,
  slugs,
  docData: serializedDocData,
  defaultUpdatedAt: String(defaultDocData.updatedAt),
  docContent,
  nextDoc,
  prevDoc,
};
---

<BaseLayout
  locale={locale}
  title={`${docData.title} | Intlayer`}
  description={docData.description}
>
  <script
    id="doc-page-props"
    type="application/json"
    set:html={JSON.stringify(docPageProps).replace(/<\//g, '<\\/')}
  />
  <div transition:persist="doc-page-island" class="contents">
    <DocPageIsland
      {...docPageProps}
      client:load
    />
  </div>
</BaseLayout>
