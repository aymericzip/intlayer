---
import { getPreviousNextBlogData } from '@components/BlogPage/blogData';
import { Website_Blog_Path } from '@intlayer/design-system/routes';
import { type BlogKey, getBlog, getBlogMetadataBySlug } from '@intlayer/docs';
import { urlRenamer } from '@utils/markdown';
import {
  getLocaleFromPath,
  getLocalizedUrl,
  getPrefix,
  type LocalesValues,
  localeMap,
} from 'intlayer';
import { BlogPageIsland } from '@/components/islands/BlogPageIsland';
import BaseLayout from '@/layouts/BaseLayout.astro';

export const prerender = true;

export const getStaticPaths = async () => {
  const blogMetadata = await getBlogMetadataBySlug([]);
  const paths = [];

  for (const { locale } of localeMap(({ locale }) => ({ locale }))) {
    for (const meta of blogMetadata) {
      // meta.slugs starts with "blog" — strip it since "blog" is already in the path.
      const slugsParam = meta.slugs.slice(1).join('/');
      // Skip paths handled by dedicated static routes to avoid prerender conflicts.
      if (!slugsParam || slugsParam === 'search') continue;
      paths.push({
        params: {
          locale: getPrefix(locale).localePrefix,
          slugs: slugsParam,
        },
        props: { locale, slugs: meta.slugs.slice(1) },
      });
    }
  }

  return paths;
};

const { locale: localeProp, slugs: slugsProp } = Astro.props as {
  locale: LocalesValues;
  slugs: string[];
};
const locale =
  localeProp ?? (getLocaleFromPath(Astro.url.pathname) as LocalesValues);
const slugs =
  slugsProp ??
  (Astro.params.slugs ? String(Astro.params.slugs).split('/') : []);

const blogsData = await getBlogMetadataBySlug(slugs, locale);
const filteredBlogsData = blogsData.filter(
  (blog) => blog.slugs.length === slugs.length + 1
);

if (!filteredBlogsData || filteredBlogsData.length === 0) {
  return Astro.redirect(Website_Blog_Path);
}

const blogData = filteredBlogsData[0];
const { prevBlogData, nextBlogData } = getPreviousNextBlogData(
  blogData.docKey as BlogKey,
  locale
);
const file = await getBlog(blogData?.docKey as BlogKey, locale);
const blogContent = urlRenamer(file, locale);

const nextBlog = nextBlogData?.blogs
  ? {
      title: nextBlogData.title,
      url: getLocalizedUrl(nextBlogData.blogs.relativeUrl, locale),
    }
  : undefined;
const prevBlog = prevBlogData?.blogs
  ? {
      title: prevBlogData.title,
      url: getLocalizedUrl(prevBlogData.blogs.relativeUrl, locale),
    }
  : undefined;

const serializedBlogData = {
  title: blogData.title,
  description: blogData.description,
  keywords: blogData.keywords,
  createdAt: String(blogData.createdAt),
  updatedAt: String(blogData.updatedAt),
  url: blogData.url,
  docKey: String(blogData.docKey),
  githubUrl: blogData.githubUrl ?? '',
  relativeUrl: blogData.relativeUrl ?? '',
  applicationTemplate: blogData.applicationTemplate,
  applicationShowcase: blogData.applicationShowcase,
  youtubeVideo: blogData.youtubeVideo,
  author: blogData.author,
  history: (blogData.history ?? []).map((h: any) => ({
    date: String(h.date),
    version: String(h.version ?? ''),
    changes: String(h.changes ?? ''),
  })),
  slugs: blogData.slugs,
};
---

<BaseLayout
  locale={locale}
  title={`${blogData.title} | Intlayer`}
  description={blogData.description}
>
  <BlogPageIsland
    locale={locale}
    slugs={slugs}
    blogData={serializedBlogData}
    blogContent={blogContent}
    nextBlog={nextBlog}
    prevBlog={prevBlog}
    client:load
  />
</BaseLayout>
