---
export const prerender = false;

import { urlRenamer } from '@utils/markdown';
import { assertSafeRemoteMarkdownUrl } from '@utils/remoteMarkdownUrl';
import { getIntlayer, getLocaleFromPath, type LocalesValues } from 'intlayer';
import { MarkdownPreviewIsland } from '@/components/islands/MarkdownPreviewIsland';
import BaseLayout from '@/layouts/BaseLayout.astro';

const locale = getLocaleFromPath(Astro.url.pathname) as LocalesValues;
const rawUrl = Astro.url.searchParams.get('url') ?? undefined;

let markdownContent: string | undefined;
let errorMessage: string | undefined;

if (rawUrl) {
  try {
    const source = assertSafeRemoteMarkdownUrl(rawUrl);
    const response = await fetch(source.toString(), {
      headers: { Accept: 'text/markdown, text/plain, */*' },
      signal: AbortSignal.timeout(20_000),
    });
    if (!response.ok) {
      throw new Error(`Failed to load markdown (${response.status})`);
    }
    const rawMarkdown = await response.text();
    markdownContent = urlRenamer(rawMarkdown, locale);
  } catch (err) {
    const { unknownLoadError } = getIntlayer('markdown-preview-page', locale);
    errorMessage =
      err instanceof Error ? err.message : String(unknownLoadError);
  }
}
---

<BaseLayout locale={locale} title="Markdown Preview | Intlayer">
  <MarkdownPreviewIsland
    locale={locale}
    content={markdownContent}
    errorMessage={errorMessage}
    hasUrl={!!rawUrl}
    client:load
  />
</BaseLayout>
