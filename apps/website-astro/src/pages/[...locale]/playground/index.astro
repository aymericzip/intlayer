---
import {
  getIntlayer,
  getLocaleFromPath,
  getPrefix,
  type LocalesValues,
  localeMap,
} from 'intlayer';
import { PlaygroundIsland } from '@/components/islands/PlaygroundIsland';
import BaseLayout from '@/layouts/BaseLayout.astro';

export const prerender = true;

export const getStaticPaths = () =>
  localeMap(({ locale }) => ({
    params: { locale: getPrefix(locale).localePrefix },
  }));

const locale = getLocaleFromPath(Astro.url.pathname) as LocalesValues;
const { title, description } = getIntlayer('playground-metadata', locale);
const applicationURL = `${import.meta.env.PUBLIC_URL ?? 'https://intlayer.org'}/demo`;
---

<BaseLayout
  locale={locale}
  title={String(title)}
  description={String(description)}
>
  <PlaygroundIsland locale={locale} applicationURL={applicationURL} client:load />
</BaseLayout>
