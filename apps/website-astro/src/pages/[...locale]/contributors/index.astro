---
import type { Contributor } from '@components/Contributors/ContributorsList';
import {
  getIntlayer,
  getLocaleFromPath,
  getPrefix,
  type LocalesValues,
  localeMap,
} from 'intlayer';
import { ContributorsIsland } from '@/components/islands/ContributorsIsland';
import BaseLayout from '@/layouts/BaseLayout.astro';

export const prerender = true;

export const getStaticPaths = () =>
  localeMap(({ locale }) => ({
    params: { locale: getPrefix(locale).localePrefix },
  }));

const locale = getLocaleFromPath(Astro.url.pathname) as LocalesValues;
const { title, description } = getIntlayer('contributors-metadata', locale);

let contributors: Contributor[] = [];
try {
  const response = await fetch(
    'https://api.github.com/repos/aymericzip/intlayer/contributors'
  );
  if (response.ok) {
    const data: Contributor[] = await response.json();
    contributors = data.filter(
      (contributor) =>
        contributor.type !== 'Bot' && !contributor.login.includes('[bot]')
    );
  }
} catch (error) {
  console.error('Error fetching contributors:', error);
}
---

<BaseLayout
  locale={locale}
  title={String(title)}
  description={String(description)}
>
  <ContributorsIsland
    locale={locale}
    contributors={contributors}
    client:load
  />
</BaseLayout>
