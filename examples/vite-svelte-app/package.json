{
  "name": "vite-svelte-app-example",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun --bun vite build",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "dev": "bun --bun vite",
    "preview": "bun --bun vite preview",
    "start:editor": "bun intlayer-editor start --with 'vite dev'"
  },
  "dependencies": {
    "intlayer": "workspace:*",
    "svelte-intlayer": "workspace:*"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tsconfig/svelte": "5.0.8",
    "@types/node": "25.9.4",
    "intlayer-editor": "workspace:*",
    "svelte": "5.55.8",
    "svelte-check": "4.4.8",
    "typescript": "7.0.2",
    "vite": "8.1.3",
    "vite-intlayer": "workspace:*"
  }
}
