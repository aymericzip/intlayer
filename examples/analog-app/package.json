    "@angular/build": "21.2.12",
    "@angular/cli": "21.2.12",
    "@angular/compiler-cli": "21.2.14",
    "intlayer-editor": "workspace:*",
    "jsdom": "29.1.1",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vite-intlayer": "workspace:*",
    "vitest": "4.1.7"
  },
  "engines": {
    "node": ">=20.19.1"
