{
  "name": "analog-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun --bun vite build",
    "dev": "bun --bun vite",
    "ng": "ng",
    "preview": "node dist/analog/server/index.mjs",
    "start": "bun run dev",
    "start:editor": "bun intlayer-editor start -e development --with 'vite dev'",
    "test": "bun --bun vitest",
    "watch": "bun --bun vite build --watch"
  },
  "dependencies": {
    "@analogjs/content": "2.5.1",
    "@analogjs/router": "2.5.1",
    "@angular/animations": "21.2.14",
