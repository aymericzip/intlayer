{
  "name": "tanstack-start-intlayer",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "bun --bun vite dev --port 3000",
    "start": "node .output/server/index.mjs",
    "build": "bun --bun vite build",
    "serve": "bun --bun vite preview",
    "test": "bun --bun vitest run",
    "typecheck": "tsc --noEmit --project tsconfig.types.json",
    "start:editor": "bun intlayer-editor start -e development",
    "intlayer:build": "intlayer build"
  },
  "dependencies": {
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/react-query": "5.101.0",
    "@tanstack/react-router": "1.170.11",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/react-router-ssr-query": "1.167.1",
    "@tanstack/react-start": "1.168.20",
    "@tanstack/router-plugin": "1.168.14",
    "intlayer": "workspace:*",
    "nitro": "latest",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-intlayer": "workspace:*",
    "tailwindcss": "4.3.0"
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "jsdom": "29.1.1",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vite-intlayer": "workspace:*",
    "vitest": "4.1.8",
    "web-vitals": "5.2.0"
  }
}
