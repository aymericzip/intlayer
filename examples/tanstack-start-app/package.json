{
  "name": "tanstack-start-intlayer",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "bun --bun vite dev --port 3000",
    "start": "node .output/server/index.mjs",
    "build": "bun --bun vite build",
    "serve": "bun --bun vite preview",
    "test": "bun --bun vitest run",
    "typecheck": "tsc --noEmit --project tsconfig.types.json",
    "start:editor": "bun intlayer-editor start -e development",
    "intlayer:build": "intlayer build"
  },
  "dependencies": {
    "@tailwindcss/vite": "4.2.2",
    "@tanstack/react-query": "5.96.2",
    "@tanstack/react-router": "1.168.10",
    "@tanstack/react-router-devtools": "1.166.11",
    "@tanstack/react-router-ssr-query": "1.166.10",
    "@tanstack/react-start": "1.167.16",
    "@tanstack/router-plugin": "1.167.12",
    "intlayer": "workspace:*",
    "nitro": "latest",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-intlayer": "workspace:*",
    "tailwindcss": "4.2.2"
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "jsdom": "29.0.2",
    "typescript": "6.0.2",
    "vite": "8.0.7",
    "vite-intlayer": "workspace:*",
    "vitest": "4.1.3",
    "web-vitals": "5.1.0"
  }
}
