    "next-intlayer": "workspace:*",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "15.5.14",
    "@tailwindcss/postcss": "4.2.2",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "intlayer-editor": "workspace:*",
    "postcss": "8.5.10",
    "tailwindcss": "4.2.2",
