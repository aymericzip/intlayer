{
  "name": "nextjs-15-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "bun --bun next build",
    "build:turbo": "bun --bun next build --turbopack",
    "dev": "bun --bun next dev",
    "dev:turbo": "bun intlayer watch --with 'bun --bun next dev --turbopack'",
    "lint": "bun --bun next lint",
    "start": "bun --bun next start",
    "start:editor": "bun intlayer-editor start",
    "start:live": "bun intlayer live --with 'bun --bun next start'",
    "test": ""
  },
  "dependencies": {
    "fuse.js": "7.3.0",
    "intlayer": "workspace:*",
    "next": "15.5.18",
    "next-intlayer": "workspace:*",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "15.5.18",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "intlayer-editor": "workspace:*",
    "postcss": "8.5.15",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3"
  }
}
