    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint-config-next": "16.2.0",
    "intlayer-editor": "workspace:*",
    "tailwindcss": "4.3.3",
    "typescript": "6.0.3"
  }
